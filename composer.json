{
    "name": "amondar-libs/php-state-flow",
    "description": "A simple library to help with USA state flows in PHP with in-memory cache support inside a single process",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sereda Oleg (Amondar)",
            "homepage": "https://github.com/amondar-libs"
        }
    ],
    "keywords": [
        "laravel",
        "php",
        "states",
        "USA states"
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.24",
        "spatie/laravel-ray": "^1.41",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Amondar\\PhpStateFlow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "ppest": "pest --parallel"
    }
}
