{
    "name": "amondar-libs/php-state-flow",
    "description": "A lightweight PHP package for working with U.S. state codes and names.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sereda Oleg (Amondar)",
            "homepage": "https://github.com/amondar-libs"
        }
    ],
    "keywords": [
        "php",
        "states",
        "USA states",
        "US states",
        "US state codes",
        "US state names",
        "US state abbreviations",
        "US state flow",
        "US state lookup",
        "US state validation",
        "US state parser",
        "US state regex",
        "US state flow"
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.24",
        "spatie/laravel-ray": "^1.41",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Amondar\\PhpStateFlow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "ppest": "pest --parallel"
    }
}
